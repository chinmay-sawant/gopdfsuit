# Copia a .env en la raíz del repo: cp .env.example .env

# Google OAuth — opcional en local (solo si VITE_IS_CLOUD_RUN=true)
# VITE_GOOGLE_CLIENT_ID=

# Desarrollo local (backend: make dev / make docker → :8080)
VITE_IS_CLOUD_RUN=false
VITE_ENVIRONMENT=local
VITE_API_URL=http://localhost:8080

# Cloud Run (descomenta y ajusta para producción)
# VITE_IS_CLOUD_RUN=true
# VITE_ENVIRONMENT=cloudrun
# VITE_CLOUD_RUN_URL=https://your-service.run.app
# VITE_API_URL=https://your-service.run.app
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
