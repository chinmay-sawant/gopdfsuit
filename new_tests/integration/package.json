{
  "name": "gopdfsuit-e2e",
  "private": true,
  "description": "End-to-end tests (Playwright) for gopdfsuit",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test -c playwright.cloudrun.config.js",
    "test:all": "playwright test && playwright test -c playwright.cloudrun.config.js",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
