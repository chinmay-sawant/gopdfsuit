# Auto-detect text files and normalize line endings where appropriate
* text=auto

# Force LF for shell scripts and Makefiles
*.sh text eol=lf
makefile text eol=lf
Makefile text eol=lf

# Force CRLF for PowerShell scripts on Windows
*.ps1 text eol=crlf

# Mark common binary formats
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.wasm binary
*.prof binary
*.icc binary
*.snap binary

